# Used at BUILD TIME only — never sent to the browser.
# Copy to .env and fill in values from your API server's .env.

# Shared app token (x-app-token header, required for all API requests)
# Must be VITE_ prefixed so Vite exposes it to client-side code at runtime.
VITE_APP_TOKEN=

# Admin key for GET /stats (x-admin-key header)
ADMIN_KEY=
